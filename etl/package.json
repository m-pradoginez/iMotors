{
  "name": "imotors-etl",
  "version": "1.0.0",
  "description": "ETL Pipeline for iMotors (FIPE + Inmetro)",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "db:migrate": "ts-node src/db/migrate.ts",
    "etl:run": "ts-node src/index.ts",
    "pipeline:fipe": "ts-node src/pipeline/fipe.ts",
    "pipeline:inmetro": "ts-node src/pipeline/inmetro.ts",
    "pipeline:cross-reference": "ts-node src/pipeline/crossReference.ts",
    "validate": "ts-node src/db/validateData.ts || echo 'Validation script not yet implemented'",
    "db:count:vehicles": "psql $DATABASE_URL -c 'SELECT COUNT(*) FROM vehicles;'"
  },
  "keywords": ["etl", "fipe", "vehicles"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "axios-retry": "^4.0.0",
    "dotenv": "^16.3.0",
    "pg": "^8.11.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.8.0",
    "@types/pg": "^8.10.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
